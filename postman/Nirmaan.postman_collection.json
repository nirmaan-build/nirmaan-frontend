    {
      "name": "Admin",
      "description": "Stage 3 thin admin (PRD-04 §4.4, §4.5). These requests use the separate {{adminToken}}, not the user accessToken. Run 'Admin Login' first.",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "if (res.accessToken) { pm.environment.set('adminToken', res.accessToken); console.log('Saved adminToken for', res.email); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
