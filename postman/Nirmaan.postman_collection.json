    {
      "name": "Quotes",
      "item": [
        {
          "name": "Submit Quote (Supplier)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) { pm.environment.set('quoteId', res.id); console.log('Saved quoteId =', res.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
