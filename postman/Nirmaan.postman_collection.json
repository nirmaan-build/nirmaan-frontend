                  "if (res.id) pm.environment.set('userId', res.id);",
                  "console.log('profileComplete:', res.profileComplete, '| area:', res.primaryPincode);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "GET /users/me -> profile + role flags. Requires Bearer token (inherited)."
          }
        },
        {
          "name": "Update Me (Onboarding)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "console.log('profileComplete now:', res.profileComplete);"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{fullName}}\",\n  \"primaryPincode\": \"{{pincode}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "PATCH /users/me -> updates name / pincode / isSupplier. Sets profileComplete=true once name + active pincode are present. Pincode must be active or you get 400 AREA_NOT_SERVICEABLE."
          }
        },
