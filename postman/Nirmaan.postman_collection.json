    {
      "name": "RFQ (Post Requirement)",
      "item": [
        {
          "name": "Create RFQ (triggers matching)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201/200', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "const res = pm.response.json();",
                  "if (res.id) pm.environment.set('rfqId', res.id);",
                  "console.log('RFQ status:', res.status, '| leads:', (res.leads || []).length);",
                  "if (res.leads && res.leads.length) {",
                  "  pm.environment.set('leadId', res.leads[0].id);",
                  "  console.log('Saved leadId =', res.leads[0].id, '(a Lead was auto-created -> matching works)');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"pincode\": \"{{pincode}}\",\n  \"description\": \"Need 200 bags OPC cement for a slab pour next week\",\n  \"quantity\": 200,\n  \"unit\": \"bag\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/rfqs",
              "host": ["{{baseUrl}}"],
              "path": ["rfqs"]
            },
            "description": "POST /rfqs -> creates the RFQ and runs synchronous matching (Lead per matching supplier). Saves rfqId + first leadId."
          }
        },
        {
          "name": "List My RFQs",
