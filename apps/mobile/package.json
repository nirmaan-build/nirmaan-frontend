{
  "name": "@nirmaan/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Nirmaan mobile app (React Native CLI, bare) — Android-first.",
  "scripts": {
    "start": "react-native start --reset-cache",
    "s": "react-native start",
    "android": "react-native run-android",
    "a": "react-native run-android",
    "ios": "react-native run-ios",
    "i": "react-native run-ios",
    "pods": "cd ios && RCT_NEW_ARCH_ENABLED=1 bundle exec pod install",
    "lint": "eslint .",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nirmaan/shared": "workspace:*",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "^7.3.0",
    "@tanstack/react-query": "^5.62.0",
    "lucide-react-native": "^1.20.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-bootsplash": "^6.3.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.2.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
